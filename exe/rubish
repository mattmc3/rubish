#!/usr/bin/env ruby
# frozen_string_literal: true

# Check for profiling early, before loading anything
rubish_prof = ENV['RUBISH_PROF'] == '1' || ARGV.include?('--prof')

if rubish_prof
  require_relative '../lib/rubish/startup_profiler'
  Rubish::StartupProfiler.start!
end

# For system Ruby where reline isn't bundled,
# add user-installed reline path directly to bypass dependency checks
if rubish_prof
  Rubish::StartupProfiler.measure('require reline') do
    begin
      require 'reline'
    rescue LoadError
      require 'rubygems'
      reline_lib = Dir.glob(File.join(Gem.user_dir, 'gems', 'reline-*', 'lib')).max
      $LOAD_PATH.unshift(reline_lib) if reline_lib
    end
  end

  Rubish::StartupProfiler.measure('require rubish') do
    require_relative '../lib/rubish'
  end
else
  begin
    require 'reline'
  rescue LoadError
    require 'rubygems'
    reline_lib = Dir.glob(File.join(Gem.user_dir, 'gems', 'reline-*', 'lib')).max
    $LOAD_PATH.unshift(reline_lib) if reline_lib
  end

  require_relative '../lib/rubish'
end

# Detect login shell from $0 (starts with '-')
# This is the traditional way shells detect login mode
login_shell = $0.start_with?('-')

# Detect restricted shell from $0 (invoked as rbash, rrubish, or similar)
shell_basename = File.basename($0).sub(/\A-/, '')  # Remove leading '-' for login shells
restricted = shell_basename == 'rbash' || shell_basename == 'rrubish'

# Parse command line options
command_string = nil
script_file = nil
script_args = []
no_profile = false
no_rc = false
force_interactive = false
rcfile = nil  # Custom RC file (--rcfile, --init-file)
read_stdin = false  # -s: read commands from stdin

i = 0
while i < ARGV.length
  case ARGV[i]
  when '-c'
    # Execute command string
    command_string = ARGV[i + 1]
    i += 2
    # Remaining args become positional parameters
    script_args = ARGV[i..]
    break
  when '-l', '--login'
    # Force login shell mode
    login_shell = true
    i += 1
  when '-r'
    # Enable restricted shell mode
    restricted = true
    i += 1
  when '-i'
    # Force interactive mode
    force_interactive = true
    i += 1
  when '-s'
    # Read commands from stdin (remaining args become positional parameters after parsing)
    read_stdin = true
    i += 1
  when '--noprofile'
    # Don't read profile files (for login shells)
    no_profile = true
    i += 1
  when '--norc'
    # Don't read ~/.bashrc or ~/.rubishrc (for interactive non-login shells)
    no_rc = true
    i += 1
  when '--rcfile', '--init-file'
    # Use specified file instead of ~/.bashrc for interactive shells
    rcfile = ARGV[i + 1]
    i += 2
  when /\A--rcfile=(.+)\z/, /\A--init-file=(.+)\z/
    # Handle --rcfile=FILE syntax
    rcfile = $1
    i += 1
  when '--prof'
    # Enable startup profiling (already handled above, just skip)
    i += 1
  when '--'
    # End of options
    i += 1
    script_file = ARGV[i]
    script_args = ARGV[i + 1..] if ARGV[i + 1]
    break
  when /\A--(.+)/
    # Unknown long option
    $stderr.puts "rubish: --#{$1}: invalid option"
    exit 2
  when /\A-(.+)/
    # Unknown short option(s) - could be combined like -xyz
    $1.each_char do |c|
      $stderr.puts "rubish: -#{c}: invalid option"
    end
    exit 2
  else
    if read_stdin
      # With -s, remaining args are positional parameters
      script_args = ARGV[i..] || []
    else
      # Script file
      script_file = ARGV[i]
      script_args = ARGV[i + 1..] || []
    end
    break
  end
end

# Helper to source RUBISH_ENV/BASH_ENV file in non-interactive modes
def source_rubish_env(repl)
  # Check RUBISH_ENV first, then BASH_ENV as fallback (bash compatibility)
  rubish_env = ENV['RUBISH_ENV'] || ENV['BASH_ENV']
  return unless rubish_env && !rubish_env.empty?

  # Expand the path (handle ~ and variables)
  expanded_path = File.expand_path(rubish_env)
  return unless File.exist?(expanded_path)

  begin
    # Read and execute each line using the repl's execute method
    # This ensures functions/aliases are defined in the repl's context
    File.readlines(expanded_path, chomp: true).each do |line|
      next if line.strip.empty? || line.strip.start_with?('#')

      repl.send(:execute, line)
    end
  rescue StandardError => e
    $stderr.puts "rubish: #{expanded_path}: #{e.message}"
  end
end

if command_string
  # -c mode: execute command string
  ENV['RUBISH_EXECUTION_STRING'] = command_string
  repl = Rubish::REPL.new(no_rc: no_rc, rcfile: rcfile)
  repl.script_name = script_args[0] || 'rubish'
  repl.positional_params = script_args[1..] || []

  # Enable interactive mode if -i was specified
  Rubish::Builtins.enable_interactive_mode if force_interactive

  # Source interactive startup files if -i was specified
  if force_interactive && !no_rc
    repl.send(:load_interactive_config)
  else
    # Source RUBISH_ENV for non-interactive mode
    source_rubish_env(repl)
  end

  # Enable restricted mode AFTER sourcing startup files
  Rubish::Builtins.enable_restricted_mode if restricted

  exit_code = catch(:exit) { repl.send(:execute, command_string) }
  last_status = exit_code || repl.instance_variable_get(:@last_status) || 0
  exit(last_status)
elsif read_stdin
  # -s mode: read commands from stdin, args are positional parameters
  repl = Rubish::REPL.new(no_rc: no_rc, rcfile: rcfile)
  repl.script_name = script_args[0] || 'rubish'
  repl.positional_params = script_args

  # Enable interactive mode if -i was specified
  Rubish::Builtins.enable_interactive_mode if force_interactive

  # Source startup files based on mode
  if force_interactive && !no_rc
    repl.send(:load_interactive_config)
  else
    source_rubish_env(repl)
  end

  # Enable restricted mode AFTER sourcing startup files
  Rubish::Builtins.enable_restricted_mode if restricted

  # Read and execute commands from stdin
  exit_code = catch(:exit) do
    $stdin.each_line(chomp: true) do |line|
      next if line.strip.empty? || line.strip.start_with?('#')

      repl.send(:execute, line)
    end
    nil
  end

  last_status = exit_code || repl.instance_variable_get(:@last_status) || 0
  exit(last_status)
elsif script_file && !force_interactive
  # Script mode: execute script file (non-interactive)
  repl = Rubish::REPL.new
  repl.script_name = script_file
  repl.positional_params = script_args

  # Source RUBISH_ENV before executing script
  source_rubish_env(repl)

  # Enable restricted mode AFTER sourcing env file
  Rubish::Builtins.enable_restricted_mode if restricted

  # Use source to execute the script (handles multi-line strings properly)
  # Pass script_args so they become positional params in the script
  Rubish::Builtins.source([script_file] + script_args)
  last_status = repl.instance_variable_get(:@last_status) || 0
  exit(last_status)
elsif script_file && force_interactive
  # Script mode with -i: run script with interactive settings (sources bashrc)
  repl = Rubish::REPL.new(no_rc: no_rc, rcfile: rcfile)
  repl.script_name = script_file
  repl.positional_params = script_args

  # Enable interactive mode
  Rubish::Builtins.enable_interactive_mode

  # Source interactive startup files
  repl.send(:load_interactive_config) unless no_rc

  # Enable restricted mode AFTER startup files
  Rubish::Builtins.enable_restricted_mode if restricted

  # Use source to execute the script (handles multi-line strings properly)
  Rubish::Builtins.source([script_file] + script_args)

  last_status = repl.instance_variable_get(:@last_status) || 0
  exit(last_status)
else
  # Interactive mode
  repl = Rubish::REPL.new(
    login_shell: login_shell,
    no_profile: no_profile,
    no_rc: no_rc,
    restricted: restricted,
    rcfile: rcfile
  )
  Rubish::Builtins.enable_interactive_mode
  exit repl.run
end
