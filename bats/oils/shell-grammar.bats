  rubish_out=$($RUBISH -c "$cmd" 2>&1); rubish_exit=$?
  [ "$bash_exit" = "$rubish_exit" ] && [ "$bash_out" = "$rubish_out" ]
}

@test '019 For loop' {
  local cmd='# TODO: need to add variables
for name in word_a word_b word_c
do
